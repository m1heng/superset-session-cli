{
  "name": "superset-session-cli",
  "version": "0.1.0",
  "description": "CLI to list and attach to Superset terminal daemon sessions (local or remote via SSH)",
  "type": "module",
  "bin": {
    "superset-session": "src/cli.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "keywords": [
    "superset",
    "terminal",
    "ssh",
    "session",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/m1heng/superset-session-cli"
  },
  "license": "MIT",
  "scripts": {
    "build": "bun build src/cli.ts --compile --outfile superset-session",
    "build:all": "bun run build:darwin-arm64 && bun run build:darwin-x64 && bun run build:linux-arm64 && bun run build:linux-x64",
    "build:darwin-arm64": "bun build src/cli.ts --compile --target=bun-darwin-arm64 --outfile dist/superset-session-darwin-arm64",
    "build:darwin-x64": "bun build src/cli.ts --compile --target=bun-darwin-x64 --outfile dist/superset-session-darwin-x64",
    "build:linux-arm64": "bun build src/cli.ts --compile --target=bun-linux-arm64 --outfile dist/superset-session-linux-arm64",
    "build:linux-x64": "bun build src/cli.ts --compile --target=bun-linux-x64 --outfile dist/superset-session-linux-x64",
    "dev": "bun run src/cli.ts"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
